// This schema file was generated by the Local Server Agent
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      String   @default("AGENT") // SUPER_ADMIN, ADMIN, MANAGER, AGENT
  password  String   // Hashed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Terminal {
  id           String   @id @default(uuid())
  name         String
  location     String
  city         String?
  region       String?
  status       String   @default("ONLINE") // ONLINE, OFFLINE, MAINTENANCE
  lockers      Locker[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Locker {
  id          String   @id @default(uuid())
  displayId   String   // e.g. "A-01"
  doorNumber  Int
  size        String   // SMALL, MEDIUM, LARGE, XLARGE
  status      String   @default("AVAILABLE") // AVAILABLE, OCCUPIED, MAINTENANCE
  terminalId  String
  terminal    Terminal @relation(fields: [terminalId], references: [id])
  packages    Package[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Package {
  id             String   @id @default(uuid())
  waybill        String   @unique // e.g. "LQ-2024-00001"
  status         String   // PENDING, IN_TRANSIT, DELIVERED_TO_LOCKER, PICKED_UP, EXPIRED
  customerName   String?
  customerPhone  String?
  customerEmail  String?
  pickupCode     String?
  
  // Relations
  lockerId       String?
  locker         Locker?  @relation(fields: [lockerId], references: [id])
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
